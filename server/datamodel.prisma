
enum JOB_TYPE {
	FULL_TIME
	PART_TIME
	FREELANCE
	CONTRACT
}

enum STATUS_TYPE {
	FEATURED
	NEW
	OLD
	CLOSED
}

type User {
	id: ID! @id
	email: String! @unique
	password: String!
	company: Company!
	createdAt: DateTime! @createdAt
	updatedAt: DateTime! @updatedAt
}

type File {
	id: ID! @id
	base64: String!
	mimetype: String!	
	createdAt: DateTime! @createdAt
	updatedAt: DateTime! @updatedAt
}

type Company {
	id: ID! @id
	createdBy: User! @relation(link: TABLE)
	email: String!
	name: String!
	website: String!
	logo: File
	jobs: [Job!]!
	createdAt: DateTime! @createdAt
	updatedAt: DateTime! @updatedAt
}

type Invoice {
	id: ID! @id
	job: Job! @relation(link: TABLE)
	last_four_digits: Int!
	price: Int!
	status: String! @default(value:"Paid")
	createdAt: DateTime! @createdAt
	updatedAt: DateTime! @updatedAt
}

type Job {
	id: ID! @id
	position: String!
	location: String!
	salary: Int!
	description: String!
	job_type: JOB_TYPE!
	status: STATUS_TYPE!
	apply_url: String!
	company: Company 
	company_name: String
	company_email: String
	company_website: String
	invoices: [Invoice!]!
	expiresAt: DateTime!
	createdAt: DateTime! @createdAt
	updatedAt: DateTime! @updatedAt
}
